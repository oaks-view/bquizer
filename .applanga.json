{
  "app": {
    "base_language": "en",
    "push": {
      "source": [
        {
          "path": "./i18n/en/messages.toml",
          "file_format": "toml",
          "tag": "app:language.toml",
          "keepTagIds": false,
          "language": "en"
        },
        {
          "path": "./i18n/en/messages.yaml",
          "file_format": "symfony2_yaml",
          "tag": "app:language.yaml",
          "language": "en"
        }
      ]
    },
    "pull": {
      "target": [
        {
          "path": "./i18n/en/<language>.toml",
          "file_format": "toml",
          "tag": "app:language.toml",
          "export_empty": false,
          "exclude_languages": [
            "en"
          ]
        },
        {
          "path": "./i18n/en/<language>.yaml",
          "file_format": "symfony2_yaml",
          "tag": "app:language.yaml",
          "exclude_languages": [
            "en"
          ]
        }
      ]
    }
  }
}